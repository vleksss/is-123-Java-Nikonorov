<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Админка</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="page-shell single-engine">
    <main class="content full-width-content">
        <section class="hero-card">
            <div>
                <p class="eyebrow">ADMIN</p>
                <h2>Панель администратора — {{currentUsername}}</h2>
                <p>Управление пользователями и всеми аукционами системы.</p>
            </div>
            <div class="hero-actions">
                <a class="secondary-link" href="/mustache/auctions">Каталог</a>
                <a class="secondary-link" href="/mustache/profile">Профиль</a>
                {{#isOwner}}<a class="secondary-link" href="/mustache/owner/dashboard">Кабинет владельца</a>{{/isOwner}}
                <a class="secondary-link" href="/logout">Выход</a>
                <select onchange="window.location.href=this.value">
                    <option value="/thymeleaf/admin/dashboard">Thymeleaf</option>
                    <option value="/mustache/admin/dashboard" selected>Mustache</option>
                    <option value="/freemarker/admin/dashboard">FreeMarker</option>
                </select>
            </div>
        </section>

        {{#successMessage}}<div class="alert success">{{successMessage}}</div>{{/successMessage}}
        {{#errorMessage}}<div class="alert error">{{errorMessage}}</div>{{/errorMessage}}

        <div class="dashboard-grid wide-grid">
            <section class="panel-card">
                <div class="section-heading">
                    <div>
                        <p class="eyebrow">USERS</p>
                        <h3>Пользователи</h3>
                    </div>
                </div>

                <div class="table-list">
                    {{#users}}
                        <div class="table-row with-actions">
                            <div>
                                <strong>{{username}}</strong>
                                <p>{{email}}</p>
                            </div>
                            <div>
                                <strong>{{role}}</strong>
                                {{#enabled}}<p>Активен</p>{{/enabled}}
                                {{^enabled}}<p>Заблокирован</p>{{/enabled}}
                            </div>
                            <div class="row-actions stacked-actions">
                                {{#protectedUser}}
                                    <div class="tag">Недоступно</div>
                                {{/protectedUser}}

                                {{^protectedUser}}
                                    <form action="/admin/users/{{id}}/status" method="post">
                                        <input type="hidden" name="enabled" value="{{nextEnabledValue}}">
                                        <button class="danger-button" type="submit">{{statusActionLabel}}</button>
                                    </form>
                                    <form action="/admin/users/{{id}}/role" method="post">
                                        <input type="hidden" name="role" value="USER">
                                        <button class="secondary-button" type="submit">Сделать USER</button>
                                    </form>
                                    <form action="/admin/users/{{id}}/role" method="post">
                                        <input type="hidden" name="role" value="OWNER">
                                        <button class="secondary-button" type="submit">Сделать OWNER</button>
                                    </form>
                                    <form action="/admin/users/{{id}}/role" method="post">
                                        <input type="hidden" name="role" value="ADMIN">
                                        <button class="secondary-button" type="submit">Сделать ADMIN</button>
                                    </form>
                                {{/protectedUser}}
                            </div>
                        </div>
                    {{/users}}
                </div>
            </section>

            <section class="panel-card">
                <div class="section-heading">
                    <div>
                        <p class="eyebrow">AUCTIONS</p>
                        <h3>Все аукционы</h3>
                    </div>
                </div>

                <div class="table-list">
                    {{#allAuctions}}
                        <div class="table-row with-actions">
                            <div>
                                <strong>{{title}}</strong>
                                <p>{{ownerUsername}}</p>
                            </div>
                            <div>
                                <strong>{{status}}</strong>
                                <p>{{currentPrice}}</p>
                            </div>
                            <div class="row-actions">
                                <form action="/admin/auctions/{{id}}/close" method="post">
                                    <button class="danger-button" type="submit">Закрыть аукцион</button>
                                </form>
                            </div>
                        </div>
                    {{/allAuctions}}
                </div>
            </section>
        </div>
    </main>
</div>
</body>
</html>